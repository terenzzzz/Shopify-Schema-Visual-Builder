{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Build faster with schema"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Visualize, edit and generate Shopify section schema in real time."
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Rich text content",
      "default": "<p>Use the builder on the left and inspect JSON on the right.</p>"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "select",
