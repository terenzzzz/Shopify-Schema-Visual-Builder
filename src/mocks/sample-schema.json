      "label": "Layout",
      "default": "split",
      "options": [
        { "value": "split", "label": "Split" },
        { "value": "stacked", "label": "Stacked" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "radio",
      "id": "text_align",
      "label": "Text align",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
